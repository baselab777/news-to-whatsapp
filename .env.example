# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# 메시지를 보낼 채팅방 이름 (WhatsApp 앱에 표시된 이름과 정확히 일치)
WHATSAPP_CHAT_NAME=AI Papers Daily

# 하루에 보낼 최대 항목 수 (Claude가 선별한 것 중 상위 N개만 전송)
MAX_SEND=1

# ── 관심 토픽 (이것 기준으로 Claude가 필터링) ─────────────────────────────────
# 쉼표로 구분, 한국어/영어 모두 가능
# 비워두면 AI/ML 전반을 기본으로 사용
TOPICS=LLM, multimodal, AI agent, reasoning, efficient inference

# ── 스케줄 ────────────────────────────────────────────────────────────────────
SCHEDULE_TIME=08:00
SCHEDULE_DAYS=mon,tue,wed,thu,fri

# ── 기타 ──────────────────────────────────────────────────────────────────────
SKILL_FILE_PATH=./SKILL.md
DEDUP_LOG_PATH=./sent_log.json
